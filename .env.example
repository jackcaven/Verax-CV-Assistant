# Verax CV Assistant — Environment Configuration
# Copy this file to .env and fill in your API keys

# LLM Provider Selection
# Options: "openai", "anthropic", "local"
LLM_PROVIDER=anthropic

# OpenAI API Key (required if LLM_PROVIDER=openai)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API Key (required if LLM_PROVIDER=anthropic)
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Privacy Mode
# Options: "full", "template_only", "offline"
# - full: All API calls, full LLM enhancement
# - template_only: Parse CV, extract to template sections, no enhancement
# - offline: Local heuristic parser only (no API)
PRIVACY_MODE=full

# Output Formats (comma-separated)
# Options: docx, pdf, html
OUTPUT_FORMATS=docx

# Batch Processing
# Number of CVs to process in parallel (1-4 recommended)
BATCH_PARALLEL_COUNT=1

# Text Enhancement
# If True, LLM polishes CV text (requires FULL privacy mode)
ENHANCE_TEXT=true
